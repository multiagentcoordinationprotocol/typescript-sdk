{
  "name": "macp-sdk-typescript",
  "version": "0.1.0",
  "description": "TypeScript SDK for the MACP Rust runtime",
  "license": "Apache-2.0",
  "type": "commonjs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write 'src/**/*.ts' 'tests/**/*.ts' --ignore-unknown",
    "format:check": "prettier --check 'src/**/*.ts' 'tests/**/*.ts' --ignore-unknown",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "macp",
    "multi-agent",
    "coordination",
    "grpc",
    "protocol"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/multiagentcoordinationprotocol/typescript-sdk.git"
  },
  "dependencies": {
    "@macp/proto": "^0.1.0",
    "@grpc/grpc-js": "^1.14.3",
    "@grpc/proto-loader": "^0.8.0",
    "protobufjs": "^8.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.8.3",
    "vitest": "^3.0.0"
  }
}
